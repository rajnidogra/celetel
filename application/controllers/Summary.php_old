    function get_summary_user_data()
    {
        $draw = intval($this->input->get("draw"));
        $start = intval($this->input->get("start"));
        $length = intval($this->input->get("length"));   

        $user_id=$this->session->userdata("userId");
        $user_chain=$this->session->userdata("userChain");
        $filter = "";

        if(!empty($this->input->post('todate'))){
            $todate = date('Y-m-d',strtotime($this->input->post('todate')));
        }else{
            $todate = date('Y-m-d');
        }

        if(!empty($this->input->post('fromdate'))){
            $fromdate = date('Y-m-d',strtotime($this->input->post('fromdate')));
        }else{
            $fromdate = date('Y-m-d');
        }

        $filter .= " and submit_date between '$fromdate' and '$todate'";

        if($this->input->post('account')){
            $filter .= " and account = '".$this->input->post('account')."'";
        }

        if($this->input->post('user_id')){
            $filter .= " and user like '".$this->input->post('user_id')."%'";
        }else{
            $filter .= " and user like '".$user_chain."%'";
        }

        $getusers=$this->summarys->getSmSSummary($filter);
        // print_r($getusers->num_rows());die;
        $mem = array();  
        foreach($getusers->result() as $r) { 
            $perc =   ($r->status_delivered *100)/$r->submit_count;
           $mem[] = array(
                // date('Y-m-d',strtolower($r->submit_date)),
                $r->submit_date,
                $r->username,
                //s$r->smsc,
                $perc,
                $r->submit_count,
                $r->dlr_count,
                $r->status_delivered,
                $r->status_failed,
                $r->status_pending,
                $r->status_nack,
            );     

        }

        $output = array(
            "draw" => $draw,
            "recordsTotal" => $getusers->num_rows(),
            "recordsFiltered" => $getusers->num_rows(),
            "data" => $mem
        );

        echo json_encode($output);
        exit(); 
    }

