    function get_campaign_tracking_data()
    {
        $draw = intval($this->input->get("draw"));
        $start = intval($this->input->get("start"));
        $length = intval($this->input->get("length"));   
        ini_set('memory_limit', -1);
        $user_id=$this->session->userdata("userId");

        $account= $this->input->post('account');
        $campaign= $this->input->post('campaign');
       
        // $getusers=$this->summarys->getCampaignTrackingData($campaign);
        $getusers=$this->summarys->getSummaryTrackingDetails($campaign,$account);
        
        $mem = array();  
        $i = 1;
        foreach($getusers->result() as $r) {   
            $clicks = '<a href="'.base_url('summary/campaignTracking').'?account='.$r->account.'&campaign='.$r->campaign.'&campaign_date='.$r->campaign_date.'">'.$r->clicks.'</a>';
            
            //  $mem[] = array(
            //     $i,
            //     $r->campaign_name,
            //     $r->contact,
            //     $r->keyword,
            //     $r->url,
            //     $r->timestamp,
            //     $r->clicks,
            // );
            $mem[] = array(
                $i,
                $r->account,
                $r->campaign,
                $r->campaign_date,
                $clicks,    
                ); 
             $i++;
        }
        $output = array(
            "draw" => $draw,
            "recordsTotal" => $getusers->num_rows(),
            "recordsFiltered" => $getusers->num_rows(),
            "data" => $mem
        );

        echo json_encode($output);
        exit(); 
    }

