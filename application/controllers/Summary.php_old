<?php
defined('BASEPATH') OR exit('No direct script access allowed');
class Summary extends CI_Controller {

	function __construct() {
        parent::__construct();
        // is_login();
        $this->load->model('user');
        $this->load->model('summarys');
    }

    function index(){
    	$data =  array();
        $user_id=$this->session->userdata("userId");
		$this->load->view('summary',$data);
    }

     function getCampaignByChain(){
        $user_id= $this->input->post('user_id');

        $getData = $this->summarys->getCampaignByChain($user_id);

        echo '<option value="">Select Campaign</option>';
        foreach ($getData as $value) {
            echo '<option value="'.$value["campaign_name"].'">'.$value["campaign_name"].'</option>';
        }
    }
    
    function getSummaryTable(){
    	$draw = intval($this->input->get("draw"));
        $start = intval($this->input->get("start"));
        $length = intval($this->input->get("length"));   

        $user_id=$this->session->userdata("userId");
        $getusers=$this->summarys->getSmppUserDetail();
        
        $mem = array();  
        $i=1;
        foreach($getusers->result() as $r) {  
        $mem[] = array(
            $i,
            $r->system_id ,
            $r->throughput,
            $r->default_smsc,
            $r->max_binds,
            $r->connect_allow_ip,
            $r->credit,
            $r->dlt,
            $r->coordinator,
            $edit.$delete.$update.$unbind
        );     
        
        $i++;
        }

        $output = array(
            "draw" => $draw,
            "recordsTotal" => $getusers->num_rows(),
            "recordsFiltered" => $getusers->num_rows(),
            "data" => $mem
        );
        echo json_encode($output);
    }

    function errorreporting(){
    	$data =  array();
        $user_id=$this->session->userdata("userId");
        $getErrordata = $this->summarys->getErrorListByGroup();
        $ErrorList = '<option selected="selected" value="">Select Error</option>';
        foreach($getErrordata as $r) {   
            $ErrorList .=  '<option value="'.$r["error"].'">'.$r["error"].'</option>';
        }
        $data['errorList'] = $ErrorList;

        $userChain = $this->session->userdata('userChain');

        $getAccountList = $this->summarys->getAccountByChain($userChain);
        $accountList = '<option selected="selected" value="">Select Account</option>';
        foreach($getAccountList as $r) {   
            $accountList .=  '<option value="'.$r["system_id"].'">'.$r["system_id"].'</option>';
        }
        $data['accountList'] = $accountList;
		$this->load->view('errorReporting',$data);
    }

    function errorReportingData(){
    	$draw = intval($this->input->get("draw"));
        $start = intval($this->input->get("start"));
        $length = intval($this->input->get("length"));   

        $user_id=$this->session->userdata("userId");

		if(!empty($this->input->post('todate'))){
			$todate = date('Y-m-d',strtotime($this->input->post('todate')));
		}else{
			$todate = date('Y-m-d');
		}

		if(!empty($this->input->post('fromdate'))){
			$fromdate = date('Y-m-d',strtotime($this->input->post('fromdate')));
		}else{
			$fromdate = date('Y-m-d');
		}

		$account = $this->input->post('account');
		$errorcode = $this->input->post('errorcode');
		$systemIds = "";

        $getusers = $this->summarys->getSummaryErrorReporting($systemIds,$user_id,$account,$errorcode,$todate,$fromdate);
        
        $mem = array();  
        foreach($getusers->result() as $r) {   
            $mem[] = array(
                ($r->submit_date)?date("d-m-Y",strtotime($r->submit_date)):"",
                $r->account,
                $r->error,
                $r->sumcount
            );  

        }     

        $output = array(
            "draw" => $draw,
            "recordsTotal" => $getusers->num_rows(),
            "recordsFiltered" => $getusers->num_rows(),
            "data" => $mem
        );
        echo json_encode($output);
    }

